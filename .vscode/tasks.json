{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "lint",
			"type": "shell",
			"command": "composer",
			"args": [
				"lint",
				"--",
				"--no-colors",
				"--report=emacs"
			],
			"group": "test",
			"problemMatcher": {
				"owner": "phpcs",
				"fileLocation": [
					"relative",
					"${workspaceFolder}"
				],
				"pattern": {
					"regexp": "^(.+):(\\d+):(\\d+):\\s+(error|warning)\\s+-\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				}
			}
		},
		{
			"label": "format",
			"type": "shell",
			"command": "composer",
			"args": [
				"format"
			],
			"group": "build",
			"problemMatcher": []
		}
	]
}
